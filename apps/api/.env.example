DATABASE_URL=postgresql://user:password@localhost:5432/moneysignal
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
API_PREFIX=/api
API_VERSION=v1
API_V1_PREFIX=/api/v1
ENABLE_LEGACY_API_PREFIX=true
REQUIRE_DB_ON_STARTUP=false

CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_WEBHOOK_SECRET=
CLERK_ISSUER=
CLERK_JWKS_URL=
CLERK_AUTH_DEBUG=false
ALLOW_DEV_AUTH=false

CACHE_ENABLED=true
CACHE_BACKEND=auto
REDIS_URL=
CACHE_KEY_PREFIX=moneysignal
CACHE_DEFAULT_TTL_SECONDS=60
CACHE_MAX_ITEMS=1000
CACHE_REDIS_SOCKET_TIMEOUT_SECONDS=3
CACHE_REDIS_CONNECT_TIMEOUT_SECONDS=3
DASHBOARD_CACHE_TTL_SECONDS=60
STOCKS_LIST_CACHE_TTL_SECONDS=60
STOCK_DETAIL_CACHE_TTL_SECONDS=60
QUOTES_READ_CACHE_TTL_SECONDS=30
MARKET_SUMMARY_CACHE_TTL_SECONDS=60
CACHE_WARM_ON_STARTUP=false
CACHE_STALE_WHILE_REVALIDATE_SECONDS=60
MARKET_DATA_PROVIDER=auto
MARKET_REQUEST_TIMEOUT_SECONDS=10
MARKET_MAX_RETRIES=2
MARKET_BACKOFF_BASE_SECONDS=0.5
MARKET_QUOTE_STALE_MINUTES=60
MARKET_MAX_BATCH_SIZE=25
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=

SEC_USER_AGENT=MoneySignalAI/0.1 contact@example.com
SEC_REQUEST_TIMEOUT_SECONDS=15
SEC_MAX_RETRIES=3
SEC_BACKOFF_BASE_SECONDS=1
SEC_MIN_REQUEST_INTERVAL_SECONDS=0.2
SEC_MAX_FILINGS=25

SCHEDULER_ENABLED=false
SCRAPER_SCHEDULE_HOURS=6
SCRAPER_DAYS_BACK=30
SCRAPER_MAX_FILINGS=10
SCRAPER_13F_MAX_FILINGS=3
SCRAPER_REFRESH_MARKET=true
SCRAPER_COOLDOWN_HOURS=6
INGESTION_MAX_RUNTIME_SECONDS=1200

LLM_PROVIDER=template
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
