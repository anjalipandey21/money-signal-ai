DATABASE_URL=postgresql://user:password@localhost:5432/moneysignal
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
API_PREFIX=/api
API_VERSION=v1
API_V1_PREFIX=/api/v1
ENABLE_LEGACY_API_PREFIX=true
REQUIRE_DB_ON_STARTUP=false

CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_WEBHOOK_SECRET=
CLERK_ISSUER=
CLERK_JWKS_URL=
CLERK_AUTH_DEBUG=false
ALLOW_DEV_AUTH=false

MARKET_DATA_PROVIDER=auto
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=

SEC_USER_AGENT=MoneySignalAI/0.1 contact@example.com
SEC_REQUEST_TIMEOUT_SECONDS=15
SEC_MAX_RETRIES=3
SEC_BACKOFF_BASE_SECONDS=1
SEC_MIN_REQUEST_INTERVAL_SECONDS=0.2
SEC_MAX_FILINGS=25

SCHEDULER_ENABLED=false
SCRAPER_SCHEDULE_HOURS=6
SCRAPER_DAYS_BACK=30
SCRAPER_MAX_FILINGS=10
SCRAPER_13F_MAX_FILINGS=3
SCRAPER_REFRESH_MARKET=true
SCRAPER_COOLDOWN_HOURS=6
INGESTION_MAX_RUNTIME_SECONDS=1200

LLM_PROVIDER=template
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
